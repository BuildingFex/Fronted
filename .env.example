# BuildingFex API (no trailing slash)
# Development: leave empty to use Vite proxy (npm run dev + backend on :5001)
VITE_API_BASE_URL=

# Production: leave empty on Vercel (rewrites in vercel.json proxy to the API).
# On other hosts, use the full URL WITH https://:
# VITE_API_BASE_URL=https://backend-production-5e544.up.railway.app

# Mercado Pago – Public Key de prueba o producción (Perú)
# VITE_MP_PUBLIC_KEY=APP_USR-your-public-key

