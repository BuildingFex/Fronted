# BuildingFex API (no trailing slash)
# Development: leave empty to use Vite proxy (npm run dev + backend on :5001)
VITE_API_BASE_URL=

# Production: required — URL of your deployed BuildingFex.Api
# VITE_API_BASE_URL=https://your-api.example.com

# Optional: dev proxy target when VITE_API_BASE_URL is empty (default http://localhost:5001)
# VITE_API_PROXY_TARGET=http://localhost:5001
