# Base URL of the json-server backend (no trailing slash). Used by the API client.
# Example: http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001

# Mercado Pago Public Key (Checkout Bricks). Use TEST key for sandbox.
# Get yours at: https://www.mercadopago.com.pe/developers/panel/app
VITE_MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
